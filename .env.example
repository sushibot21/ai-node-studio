# Copy this file to .env and fill in whichever providers you want to use.
# You only need keys for the providers you actually plan to call.
# Typical setup:
# - Ollama only: leave all API keys blank and run Ollama locally
# - Anthropic optional: add ANTHROPIC_API_KEY if you want hosted Claude models
# - MCP/Figma experiments: Anthropic can be a good model choice, but MCP write
#   permissions still depend on the external MCP server and available tools

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

PORT=8787
